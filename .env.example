# .env.example — Copier en .env et remplir les valeurs

# ── SMTP ────────────────────────────────────────────────────────
SMTP_EMAIL=votre@email.com
SMTP_PASSWORD=mot_de_passe
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_RECEIVER=destinataire@example.com

# ── Slack (optionnel) ───────────────────────────────────────────
SLACK_TOKEN=
SLACK_CHANNEL=#general

# ── Scheduler ───────────────────────────────────────────────────
SCHEDULE_DAY=monday
SCHEDULE_TIME=09:00

# ── LLM local GPT4All (optionnel) ───────────────────────────────
GPT4ALL_MODEL=
GPT4ALL_PATH=
