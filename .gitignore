# =============================================================
#  .gitignore — Veille IA Médicale
# =============================================================

# ── Fichiers sensibles (NE JAMAIS committer) ──────────────────
.env
*.env

# ── Environnements virtuels Python ───────────────────────────
.venv/
venv/
env/
ENV/

# ── Sorties générées (non versionner) ────────────────────────
historique_reports/
logs/
data/
*.pdf
*.csv

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── Outils & IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.swp
*.swo

# ── Système ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Temporaires ──────────────────────────────────────────────
*.tmp
*.bak
*.log
